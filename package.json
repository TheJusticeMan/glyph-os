{
  "name": "glyph-os",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "EXPO_USE_COMMUNITY_AUTOLINKING=1 expo run:android",
    "ios": "expo run:ios",
    "postinstall": "patch-package",
    "test": "jest --watchAll",
    "test:ci": "jest --no-coverage --watchAll=false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-launcher-kit": "^2.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@react-native-community/cli": "^20.1.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~55.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-launcher-kit)"
    ]
  },
  "private": true
}
